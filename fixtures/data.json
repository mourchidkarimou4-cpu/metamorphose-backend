: "administration.siteconfig", "pk": 18, "fields": {"cle": "morph_titre", "valeur": "Image et identité révélées", "section": "methode"}}, {"model": "administration.siteconfig", "pk": 19, "fields": {"cle": "morph_desc", "valeur": "Redéfinir son image, son style, sa posture pour que l'extérieur reflète enfin la richesse de l'intérieur. Morphologie, colorimétrie, identité visuelle.", "section": "methode"}}, {"model": "administration.siteconfig", "pk": 20, "fields": {"cle": "morph_semaines", "valeur": "Semaines 3 — 5", "section": "methode"}}, {"model": "administration.siteconfig", "pk": 21, "fields": {"cle": "ose_titre", "valeur": "Passage à l'action", "section": "methode"}}, {"model": "administration.siteconfig", "pk": 22, "fields": {"cle": "ose_desc", "valeur": "Apprendre à s'affirmer, prendre sa place, développer son leadership personnel et poser des actions concrètes vers ses rêves et ambitions.", "section": "methode"}}, {"model": "administration.siteconfig", "pk": 23, "fields": {"cle": "ose_semaines", "valeur": "Semaines 6 — 8", "section": "methode"}}, {"model": "administration.siteconfig", "pk": 24, "fields": {"cle": "programme_titre", "valeur": "8 semaines pour passer de la peur à la puissance.", "section": "programme"}}, {"model": "administration.siteconfig", "pk": 25, "fields": {"cle": "meta_items", "valeur": "Identification des croyances limitantes|Travail sur la peur du regard des autres|Développement de l'estime de soi|Introspection guidée", "section": "programme"}}, {"model": "administration.siteconfig", "pk": 26, "fields": {"cle": "morph_items", "valeur": "Conscience de son image personnelle|Morphologie et colorimétrie|Style vestimentaire et identité visuelle|Posture et présence", "section": "programme"}}, {"model": "administration.siteconfig", "pk": 27, "fields": {"cle": "ose_items", "valeur": "Affirmation de soi et art oratoire|Posture et impact|Passage à l'action concret|Plan de transformation futur", "section": "programme"}}, {"model": "administration.siteconfig", "pk": 28, "fields": {"cle": "inclus_items", "valeur": "Lives interactifs hebdomadaires|Replays à votre rythme|Exercices pratiques personnalisés|Groupe WhatsApp privé|7 guides PDF bonus|Club des Métamorphosées à vie", "section": "programme"}}, {"model": "administration.siteconfig", "pk": 29, "fields": {"cle": "prelia_titre", "valeur": "Derrière Méta'Morph'Ose, une femme engagée à révéler l'essence des femmes.", "section": "prelia"}}, {"model": "administration.siteconfig", "pk": 30, "fields": {"cle": "prelia_citation", "valeur": "Je sais ce que cela fait de se sentir invisible.", "section": "prelia"}}, {"model": "administration.siteconfig", "pk": 31, "fields": {"cle": "prelia_texte1", "valeur": "Pendant longtemps, je n'ai pas été la femme confiante que vous voyez aujourd'hui. J'ai grandi avec des blessures profondes, des doutes constants. Je me faisais petite. Je restais en retrait. Je vivais avec cette sensation permanente de ne pas être assez.", "section": "prelia"}}, {"model": "administration.siteconfig", "pk": 32, "fields": {"cle": "prelia_texte2", "valeur": "Un concours de beauté a tout changé. Pour la première fois, j'ai compris que parfois les autres voient en nous ce que nous ne sommes pas encore capables de voir nous-mêmes. C'est ce déclic qui m'a donné envie d'accompagner d'autres femmes vers leur propre révélation.", "section": "prelia"}}, {"model": "administration.siteconfig", "pk": 33, "fields": {"cle": "prelia_certifications", "valeur": "Coach en Image certifiée|Styliste|Leader Oratrice — AIL", "section": "prelia"}}, {"model": "administration.siteconfig", "pk": 34, "fields": {"cle": "prelia_signature", "valeur": "Je ne crée pas des apparences. Je révèle des essences.", "section": "prelia"}}, {"model": "administration.siteconfig", "pk": 35, "fields": {"cle": "formules_titre", "valeur": "Choisissez la formule qui correspond à votre transformation.", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 36, "fields": {"cle": "formules_intro", "valeur": "Toutes les formules incluent les 7 bonus exclusifs et l'accès au Club des Métamorphosées.", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 37, "fields": {"cle": "f1_label", "valeur": "Live · Groupe", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 38, "fields": {"cle": "f1_prix", "valeur": "65 000", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 39, "fields": {"cle": "f2_label", "valeur": "Live · Privé", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 40, "fields": {"cle": "f2_prix", "valeur": "150 000", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 41, "fields": {"cle": "f3_label", "valeur": "Présentiel · Groupe", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 42, "fields": {"cle": "f3_prix", "valeur": "250 000", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 43, "fields": {"cle": "f4_label", "valeur": "Présentiel · Privé", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 44, "fields": {"cle": "f4_prix", "valeur": "350 000", "section": "formules"}}, {"model": "administration.siteconfig", "pk": 45, "fields": {"cle": "faq_titre", "valeur": "Vous vous posez peut-être ces questions…", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 46, "fields": {"cle": "faq_q1", "valeur": "À qui s'adresse Méta'Morph'Ose ?", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 47, "fields": {"cle": "faq_r1", "valeur": "Le programme s'adresse aux femmes qui veulent se libérer du regard des autres, renforcer leur confiance, aligner leur image avec leur identité et passer à l'action avec plus d'assurance.", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 48, "fields": {"cle": "faq_q2", "valeur": "Comment se déroule l'accompagnement ?", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 49, "fields": {"cle": "faq_r2", "valeur": "Le programme dure 8 semaines avec des sessions en direct, des exercices pratiques, des replays accessibles à tout moment et un groupe communautaire privé.", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 50, "fields": {"cle": "faq_q3", "valeur": "Est-ce fait pour moi si je manque de confiance ?", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 51, "fields": {"cle": "faq_r3", "valeur": "Oui. Méta'Morph'Ose a été conçu pour les femmes qui doutent encore d'elles-mêmes mais ressentent qu'il est temps de se révéler.", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 52, "fields": {"cle": "faq_q4", "valeur": "Vais-je seulement travailler mon image ?", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 53, "fields": {"cle": "faq_r4", "valeur": "Non. Le programme agit sur trois dimensions : transformation intérieure, image personnelle et passage à l'action concret.", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 54, "fields": {"cle": "faq_q5", "valeur": "Puis-je participer depuis un autre pays ?", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 55, "fields": {"cle": "faq_r5", "valeur": "Oui. Le format Live permet de participer depuis n'importe quel pays. Les replays sont disponibles pour revoir les contenus à votre rythme.", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 56, "fields": {"cle": "faq_q6", "valeur": "Puis-je payer en plusieurs fois ?", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 57, "fields": {"cle": "faq_r6", "valeur": "Contactez-nous directement via WhatsApp pour discuter des modalités de paiement adaptées à votre situation.", "section": "faq"}}, {"model": "administration.siteconfig", "pk": 58, "fields": {"cle": "cta_titre", "valeur": "Et si votre transformation commençait aujourd'hui ?", "section": "cta"}}, {"model": "administration.siteconfig", "pk": 59, "fields": {"cle": "cta_texte", "valeur": "Vous n'avez pas besoin